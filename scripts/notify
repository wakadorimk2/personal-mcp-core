#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHANNEL_DIR="${NOTIFY_CHANNEL_DIR:-$SCRIPT_DIR/notify.d}"
CHANNEL="${NOTIFY_CHANNEL:-stdout}"
KIND=""
TITLE="${NOTIFY_TITLE:-}"
EVENT="${NOTIFY_EVENT:-generic}"
SOURCE="${NOTIFY_SOURCE:-}"
READ_STDIN="0"
CHANNEL_ARG_SET="0"
EVENT_ARG_SET="0"
ADAPTER_CHANNEL=""
DISCORD_WEBHOOK_ENV_NAME=""
DISCORD_WEBHOOK_SECRET_FILE=""

notification_kind_event() {
  case "$1" in
    ai_task_completed)
      printf '%s' "task_completed"
      ;;
    ai_task_failed)
      printf '%s' "task_failed"
      ;;
    smoke_test)
      printf '%s' "task_completed"
      ;;
    *)
      return 1
      ;;
  esac
}

notification_kind_route() {
  case "$1" in
    smoke_test)
      printf '%s' "discord-test"
      ;;
    *)
      printf '%s' ""
      ;;
  esac
}

resolve_notification_route() {
  local logical_channel="$1"

  ADAPTER_CHANNEL="$logical_channel"
  DISCORD_WEBHOOK_ENV_NAME=""
  DISCORD_WEBHOOK_SECRET_FILE=""

  case "$logical_channel" in
    discord)
      DISCORD_WEBHOOK_ENV_NAME="DISCORD_WEBHOOK_AI_STATUS"
      DISCORD_WEBHOOK_SECRET_FILE="$HOME/.config/secrets/discord_webhook.env"
      ;;
    discord-test)
      ADAPTER_CHANNEL="discord"
      DISCORD_WEBHOOK_ENV_NAME="DISCORD_WEBHOOK_AI_STATUS_TEST"
      DISCORD_WEBHOOK_SECRET_FILE="$HOME/.config/secrets/discord_test_webhook.env"
      ;;
  esac
}

usage() {
  cat <<'EOF'
usage: notify [--channel NAME] [--title TEXT] [--event NAME] [--kind NAME] [--source NAME] [--stdin] MESSAGE

Common notification wrapper for CLI tools.

Examples:
  notify "build finished"
  notify --event input-required --title "Codex" "Need approval"
  notify --kind ai_task_completed --title "Claude Code" "Task completed"
  printf 'long message' | notify --stdin --channel stdout
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --channel)
      CHANNEL="$2"
      CHANNEL_ARG_SET="1"
      shift 2
      ;;
    --kind)
      KIND="$2"
      shift 2
      ;;
    --title)
      TITLE="$2"
      shift 2
      ;;
    --event)
      EVENT="$2"
      EVENT_ARG_SET="1"
      shift 2
      ;;
    --source)
      SOURCE="$2"
      shift 2
      ;;
    --stdin)
      READ_STDIN="1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ -n "$KIND" ]]; then
  if [[ "$EVENT_ARG_SET" == "1" || "$CHANNEL_ARG_SET" == "1" ]]; then
    echo "notify: --kind cannot be combined with --event or --channel" >&2
    exit 2
  fi

  if ! EVENT="$(notification_kind_event "$KIND")"; then
    echo "notify: unknown notification kind: $KIND" >&2
    exit 2
  fi

  resolved_route="$(notification_kind_route "$KIND")"
  if [[ -n "$resolved_route" ]]; then
    CHANNEL="$resolved_route"
  fi
fi

if [[ "$READ_STDIN" == "1" ]]; then
  if [[ $# -ne 0 ]]; then
    echo "notify: --stdin cannot be combined with MESSAGE arguments" >&2
    exit 2
  fi
  MESSAGE="$(cat)"
else
  if [[ $# -lt 1 ]]; then
    echo "notify: MESSAGE is required" >&2
    usage >&2
    exit 2
  fi
  MESSAGE="$*"
fi

if [[ -z "$MESSAGE" ]]; then
  echo "notify: empty message is not allowed" >&2
  exit 2
fi

resolve_notification_route "$CHANNEL"

ADAPTER_PATH="$CHANNEL_DIR/$ADAPTER_CHANNEL"
if [[ ! -f "$ADAPTER_PATH" ]]; then
  echo "notify: channel adapter not found: $CHANNEL ($ADAPTER_PATH)" >&2
  exit 2
fi

if [[ ! -x "$ADAPTER_PATH" ]]; then
  echo "notify: channel adapter is not executable: $ADAPTER_PATH" >&2
  exit 2
fi

export NOTIFY_CHANNEL_NAME="$CHANNEL"
export NOTIFY_MESSAGE="$MESSAGE"
export NOTIFY_TITLE="$TITLE"
export NOTIFY_EVENT="$EVENT"
export NOTIFY_SOURCE="$SOURCE"
if [[ -n "$DISCORD_WEBHOOK_ENV_NAME" ]]; then
  export NOTIFY_DISCORD_WEBHOOK_ENV_NAME="$DISCORD_WEBHOOK_ENV_NAME"
  export NOTIFY_DISCORD_WEBHOOK_SECRET_FILE="$DISCORD_WEBHOOK_SECRET_FILE"
else
  unset NOTIFY_DISCORD_WEBHOOK_ENV_NAME || true
  unset NOTIFY_DISCORD_WEBHOOK_SECRET_FILE || true
fi

# Send the normalized message over stdin as well as env vars so adapters can
# choose the mechanism that fits the target platform best.
printf '%s' "$MESSAGE" | "$ADAPTER_PATH"
