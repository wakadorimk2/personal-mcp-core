#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

set +e
claude "$@"
status=$?
set -e

if [[ "$status" -eq 0 ]]; then
  event="task_completed"
  message="Claude Code task completed"
else
  event="task_failed"
  message="Claude Code exited with status $status"
fi

if ! "$REPO_ROOT/scripts/notify" \
  --event "$event" \
  --title "Claude Code" \
  --source "claude_code" \
  "$message"; then
  echo "claude-notify: notify delivery failed" >&2
fi

exit "$status"
